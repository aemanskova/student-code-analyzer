# Скопируйте в .env и подставьте значения для своего окружения:
#   cp .env.example .env

# --- Публичный URL приложения (то же, что открываете в браузере, без завершающего /)
# Локально: http://localhost:5173
# VPS (ваш домен): https://aemanskova.ru
PUBLIC_APP_URL=http://localhost:5173

# --- Backend (NestJS)
NODE_ENV=development
PORT=3000
HTTP_REQUEST_TIMEOUT_MS=0
# Разрешённый origin для CORS (должен совпадать с PUBLIC_APP_URL)
CORS_ORIGIN=http://localhost:5173

JWT_SECRET=change_me_to_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
# Раунды bcrypt (10–15). В проде рекомендуется 12+
BCRYPT_ROUNDS=12

# Доверять X-Forwarded-* за reverse proxy (Caddy/nginx) — в проде обычно да
TRUST_PROXY=true

# Swagger: в production по умолчанию выключен; включить только временно: SWAGGER_ENABLED=true
# SWAGGER_ENABLED=false

# Лимит запросов: глобально в минуту на IP (за прокси учитывается trust proxy)
THROTTLE_GLOBAL_LIMIT=400

# В production можно закрыть публичную регистрацию (учётки создавать вручную в БД)
# ALLOW_PUBLIC_REGISTRATION=false

SQLITE_DB_PATH=/app/data/sqlite/app.db
DUCKDB_PATH=/app/data/duckdb/analysis.duckdb
CSV_ROOT=/app/csv
WORKS_ROOT=/app/works

PATH_GROUP_INDEX=0
PATH_STUDENT_INDEX=1

# S3-совместимое хранилище (MinIO)
S3_BUCKET=analysis-uploads
S3_REGION=us-east-1
# Внутри Docker-сети — сервис minio
S3_ENDPOINT=http://minio:9000
# URL, который использует браузер для загрузки (пресайны). Локально:
S3_PUBLIC_ENDPOINT=http://localhost:9100
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Нагрузка / анализ (при необходимости увеличьте на мощном сервере)
NODE_OPTIONS=--max-old-space-size=1024
WORK_CONCURRENCY=1
GLOBAL_HEAVY_CONCURRENCY=2
HTML_PARSE_CONCURRENCY=2
CSS_PARSE_CONCURRENCY=2
VNU_CONCURRENCY=1
AXE_CONCURRENCY=1
FS_STAT_CONCURRENCY=32
AXE_TIMEOUT_MS=45000
ANALYSIS_ASYNC_CONCURRENCY=1

# --- MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Порты на хосте (dev / prod compose)
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9101

# Список origin через запятую (без пробелов или с пробелами — обрежутся). Должен включать PUBLIC_APP_URL
MINIO_CORS_ORIGINS=http://localhost:5173

# --- Frontend (только dev: docker-compose.yml)
# Полный URL API, если фронт на другом порте
VITE_API_URL=http://localhost:3000/api

# --- Prod build (docker-compose.prod.yml): относительный путь к API за тем же хостом
# VITE_API_URL=/api

# ========== Пример .env на VPS для aemanskova.ru (скопируйте значения в свой .env) ==========
# Порт nginx контейнера web на хосте (Caddy проксирует на 127.0.0.1:WEB_PORT). С Caddy на том же VPS — 8080
# WEB_PORT=8080
# PUBLIC_APP_URL=https://aemanskova.ru
# CORS_ORIGIN=https://aemanskova.ru
# NODE_ENV=production
# VITE_API_URL=/api
# TRUST_PROXY=true
# SWAGGER_ENABLED=false
# ALLOW_PUBLIC_REGISTRATION=false
# MINIO_CORS_ORIGINS=https://aemanskova.ru
# S3_PUBLIC_ENDPOINT=https://s3.aemanskova.ru
#   ^ публичный HTTPS к MinIO (поддомен за Caddy), не открывайте 9100 в интернет
# Смените MINIO_ROOT_* и S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY на сильные пароли и синхронизируйте их.
# JWT_SECRET=<минимум 32 символа, openssl rand -base64 48>
